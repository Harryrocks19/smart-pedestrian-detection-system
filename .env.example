# Environment Configuration for AI Insem Pedestrian Detection System
# Copy this to .env and fill in your actual values

# ── API Keys ──────────────────────────────────────────────────────────────────
# Gemini AI (for emergency detection)
GEMINI_API_KEY=your-gemini-api-key-here

# Twilio (for WhatsApp alerts)
TWILIO_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_TO=whatsapp:+91XXXXXXXXXX
TWILIO_FROM=whatsapp:+14155238886

# Telegram (for alerts)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Email (for alert notifications)
EMAIL_FROM=alerts@yourcompany.com
EMAIL_PASSWORD=your-email-password

# ── SaaS Configuration ────────────────────────────────────────────────────────
# API keys for different tenants
API_KEY_PUNE=PMC-2024-XKJH91
API_KEY_MUMBAI=MTA-2024-LMNP42
API_KEY_MALL=PHX-2024-QRST77

# Dashboard credentials
ADMIN_PASSWORD=admin123
VIEWER_PASSWORD=view789

# ── Database ──────────────────────────────────────────────────────────────────
# Optional: For PostgreSQL (leave blank to use SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/pedestrian_db

# ── Railway Deployment ────────────────────────────────────────────────────────
# Port configuration
PORT=5000
STREAMLIT_SERVER_PORT=8501

# Runtime environment
ENVIRONMENT=production
DEBUG=false

# ── Optional Features ─────────────────────────────────────────────────────────
# Cloud storage (for backup)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket-name

# Logging level
LOG_LEVEL=INFO

# ── Notes ─────────────────────────────────────────────────────────────────────
# 1. To load this file: export $(cat .env.example | xargs)
# 2. For Railway: Add variables in Railway Dashboard → Variables
# 3. For local testing: Create .env file from .env.example (don't commit .env!)
# 4. Keep API keys secure - never commit actual .env to GitHub
